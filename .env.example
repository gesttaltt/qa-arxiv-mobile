# arXiv QA Test Environment Configuration
# Copy this file to .env and uncomment/adjust values for your environment.

# Appium (mobile UI automation)
# APPIUM_SERVER_URL=http://127.0.0.1:4723
# ARXIV_APK_PATH=/tmp/arxiv-mobile-testing/arxiv-papers-mobile/android/app/build/outputs/apk/debug/app-debug.apk
# ANDROID_DEVICE_NAME=Android Emulator

# Azure DevOps pipeline variables (local simulation)
# APPIUM_ENABLED=false
